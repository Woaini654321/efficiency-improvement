# 【应用名称 & 简介】
VITE_TITLE=QMonoX Web App
VITE_TITLE_EN=QMonoX Web App
VITE_INTRODUCTION=移远多端一体化 Monorepo 前端框架 Web 端
VITE_INTRODUCTION_EN=Quectel multi-terminal integrated Monorepo front-end web app framework

# 【子包应用的唯一标识】
VITE_APP_KEY=QMonoX-Web-Admin

# 【服务端口号】
VITE_PORT=8080

# 【html部署时的base】
VITE_APP_BASE=/web

# 【移远平台应用ID】
VITE_APP_ID=QMonoX-Web

# 【移远平台应用资源code】
VITE_APP_SOURCE_CODE=QMonoX-Web-Admin

# 【优先使用平台应用资源中的图标】
VITE_USE_APP_SOURCE_ICON=N

# 【优先使用平台应用的名称作为应用标题，为 N 则取环境变量 VITE_TITLE】
VITE_USE_APP_TITLE=Y

# 【启用面包屑的记忆模式】
VITE_HISTORY_BREADCRUMB_MODE=N

# 【生产环境（特指打包部署后的环境）隐藏设置（包含主题切换）】
VITE_PRODUCTION_HIDE_SETTINGS=Y
