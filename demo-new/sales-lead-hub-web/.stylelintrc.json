{
  "extends": ["stylelint-config-standard"],
  "overrides": [
    {
      "files": ["**/*.vue"],
      "customSyntax": "postcss-html"
    },
    {
      "files": ["**/*.html"],
      "customSyntax": "postcss-html"
    }
  ],
  "rules": {
    "selector-class-pattern": null,
    "no-descending-specificity": null,
    "no-empty-source": null,
    "selector-pseudo-class-no-unknown": [
      true,
      {
        "ignorePseudoClasses": ["deep"]
      }
    ]
  },
  "ignoreFiles": [
    "**/node_modules/**",
    "**/uni_modules/**",
    "**/static/**",
    "**/dist/**",
    "**/lib/**",
    "**/cache/**"
  ]
}
