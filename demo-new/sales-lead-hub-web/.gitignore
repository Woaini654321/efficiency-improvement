# ========== 操作系统 & 通用临时文件 ==========
.DS_Store
Thumbs.db
*.local

# ========== 构建产物 & 缓存 ==========
.codegraph/
node_modules/
dist/
*-dist/
lib/
.temp/
coverage/
.cache/
cache/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ========== 编辑器目录 ==========
# WebStorm：忽略整体，也可保留可共享的 codeStyles 和 runConfigurations
.idea/*
# !.idea/codeStyles
# !.idea/runConfigurations

# VS Code：默认忽略所有 .vscode，根目录按需保留团队共享配置
**/.vscode/
!/.vscode/
/.vscode/*
!/.vscode/settings.json
!/.vscode/launch.json
!/.vscode/tasks.json
# 如果团队统一扩展也可保留（默认忽略）
# !/.vscode/extensions.json


# 其他编辑器/IDE 文件
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.hbuilderx/

# ========== 依赖锁文件（建议提交以保证一致性） ==========
# 如果需要提交锁文件，可以注释下
package-lock.json
pnpm-lock.yaml

# ========== 代码/类型定义 特殊处理 ==========
**/*/types/typed-router.d.ts
**/*/types/components.d.ts
**/*/types/uni-pages.d.ts
**/*/types/async-component.d.ts
# 单独把这个文件排除掉，用以解决部分电脑生成的 auto-import.d.ts 的API不完整导致类型提示报错问题
# **/*/types/auto-import.d.ts

# uni-app 配置（使用unibest框架，在启动或构建时自动生成，无需提交）
**/src/manifest.json
**/src/pages.json
**/src/error-pages/

# 环境变量
env/.env.customize

# ========== 文档（VitePress） ==========
**/.vitepress/dist/
**/.vitepress/cache/

# ========== 国际化工具（q-i18n-tool-node）翻译得到的文件 ==========
i18n-tool*



