# 【应用名称 & 简介】
# 这里是全局的配置，你可以在子包的env中配置来覆盖它
VITE_TITLE=QMonoX
VITE_TITLE_EN=QMonoX
VITE_INTRODUCTION=移远多端一体化 Monorepo 前端框架
VITE_INTRODUCTION_EN=Quectel multi-terminal integrated Monorepo front-end framework

# 【子包应用的唯一标识】
# 请在子包的env中配置，必填且唯一
# VITE_APP_KEY=QMonoX-Web-Admin

# 【服务端口号】
# 请在子包的env中配置，或者在子包启动指令里指定（如：q-cli-run --port 3000），避免端口混乱
# VITE_PORT=8080

# 【html部署时的base】
# eg：你要部署到 https://qmonox.tech/doc ，则配置为 /doc
# 请在子包的env中配置，或者在子包启动（或构建）指令里指定（如：q-cli-run --base /doc），
# VITE_APP_BASE=/

# 【运营管理后台平台应用ID】
# 请在子包的env中配置
# VITE_APP_ID=Q_MONO_X

# 【移远平台应用资源code】
# 说下背景原因，以及什么场景下会用到：
# 运营管理后台的应用的子级分为 PC、WEP、APP 三类平台应用，且每一类只能对应一个平台应用，
# 受限于此，当产品存在多个同类的平台应用时，只能将这些同类的平台应用合并为一个去配置，
# 举个例子，某个财务系统，其 Web 端的应用有用户端、管理端，由于财务系统的应用下面只能配置一个 WEB 类型的平台应用，
# 所以用户端和管理端的资源都需要配置在这一个平台应用下面，为了在请求资源权限数据时区分用户端和管理端，VITE_APP_SOURCE_CODE 必须要传，
# 这里 VITE_APP_SOURCE_CODE 作为平台应用下用户端和管理端的根节点的code。
#
# 简述成一句话就是：当某个平台应用下面存在多个子应用时，就需要把对应子应用的资源 code 配置给 VITE_APP_SOURCE_CODE。
# 请在子包的env中配置
# VITE_APP_SOURCE_CODE

# 【本地启动时自动打开浏览器】
# 这里是全局的配置，你可以在子包的env中配置来覆盖它
VITE_DEV_SERVER_AUTO_OPEN_BROWSER=N

# 【服务端请求地址】
# 这里是全局的配置，你可以在子包的env中配置，或者子包启动（或构建）指令里指定（如：q-cli-run --apiUrl http://web-develop.quectel.com）来覆盖它
# 开发环境
VITE_API_URL=http://web-develop.quectel.com
# 测试环境
# VITE_API_URL=http://192.168.26.84:80
# 生产环境
# VITE_API_URL=https://q-learning.quectel.com/api

# 【请求代理】
# 约定好的，一般不用修改
VITE_API_PROXY=/api

# 【是否替换接口地址中的代理字符串（VITE_API_PROXY）为空，这个取决于服务端】
# 约定好的，一般不用修改
VITE_API_PROXY_REPLACE=Y

# 【默认的微服务上下文路径，一般是对应项目的微服务】
# eg：举个例子，crm系统微服务的上下文路径为 /crm/，这里配置 /crm/ 即可，这样有个好处就是你在调用请求方法时传递的 url 不需要携带 /crm/ 前缀，后期当这个上下文变了，你修改下这里就可以了
# 这里是全局的配置，看具体场景需要你可以在子包的env中配置来覆盖它，比如：你开发的crm系统包含管理端和用户端两个端，其上下文分别为 /crm/admin/ 和 /crm/user/，这个时候你可以考虑选择在admin子包和user子包中去覆盖它，如果管理端和用户端接口有互相使用的情况则就不建议了
# VITE_API_DEFAULT_SERVICE_BASE_URL

# 【应用构建时是否要删除 console 和 debugger】
# 这里是全局的配置，你可以在子包的env中配置来覆盖它
VITE_DELETE_CONSOLE=Y

# 【应用构建时是否要生成 sourcemap】
# 这里是全局的配置，你可以在子包的env中配置来覆盖它
VITE_SOURCEMAP=N

# 【应用构建时输出的目录】
# 相对于应用子包的目录，统一将构建的产物输出到工程根目录的dist目录下（小程序、App除外），当删除或注释此环境变量后，构建产物会输出到应用子包中的dist目录下
# 解释为什么这么干？为了尽量和之前 Genkins 构建脚本一致，符合运维思维直觉
# 这里是全局的配置，你可以在子包的env中配置来覆盖它
VITE_OUT_DIR=../../dist

# 【本地启动时开启 SSO 登录模式】
# 这里是全局的配置，你可以在子包的env中配置来覆盖它
VITE_DEV_SSO_ENABLE=N

# 【本地 SSO 服务端口】
# 约定好的，一般不用修改
VITE_DEV_SSO_PORT=9999

# 【是否与 SSO 当前的语言环境保持同步（PS：跨站 SSO 场景下无法绝对的同步）】
# 约定好的，一般不用修改
VITE_SYNC_SSO_LANG=Y

# 【前端加密秘钥（用于登录时记住账号/密码）】
# 这里是全局的配置，你可以在子包的env中配置来覆盖它
VITE_SECRET=VITE_SECRET

# 【登出时调用登出接口】
# 没有开启 SSO 模式时，此配置才生效
# 这里是全局的配置，你可以在子包的env中配置来覆盖它
VITE_NEED_REQUEST_LOGOUT=Y

# 【优先使用平台应用资源中的图标】
# 建议在web管理端子包的env中配置，一般用户端、移动端的图标是UI设计的
# VITE_USE_APP_SOURCE_ICON=N

# 【优先使用运营管理后台平台应用的名称作为应用标题，为 N 则取环境变量 VITE_TITLE】
# 这里是全局的配置，你可以在子包的env中配置来覆盖它，当没有配置平台应用时，会自动使用 VITE_TITLE、VITE_TITLE_EN
# VITE_USE_APP_TITLE=Y

# 【启用面包屑的记忆模式】
# 关于 VITE_HISTORY_BREADCRUMB_MODE 的详细说明
# 一、【实验阶段功能，慎重使用！！！】开启 VITE_HISTORY_BREADCRUMB_MODE，面包屑可以记录页面每一次跳转的路由链路（每一层级的路由），以及每一层级路由的参数（route.params、route.query）
# 1）HistoryBreadcrumbStore 会记录符合父子级关系的页面跳转前后的 route.fullPath，比如从 /user 列表跳转到 /user/detail?id=1 详情页；
# 2）如果你直接访问某个深层次的路由（比如浏览器直接输入 /a/b?id=1 访问），而不是从 /a 通过类似 router.push 到 /a/b，他也会自动生成 /a 和 /a/b 的两条数据；
# 3）承接第2点，如果访问 /a 路由需要参数（如 /a?type=0），但是由于用户是直接访问的 /a/b?id=1，此时会给 /a 这条数据设置个 disabled，告诉 q-breadcrumb 点击跳转 /a 是无效的，因为缺少必要参数；
# 4）记录的数据是持久化的，刷新页面不会丢失；
#
# PS：需要知道且无法解决的问题：
# 1）由于记录的数据是持久的，所以当业务数据变动后，可能会造成变更不及时的问题，如：
#    HistoryBreadcrumbStore 记录的数据为 /a?type=0、/a/b?id=1，但是 id 为 1 的这条数据已经被修改归属为 type=6 这个分类下，此时通过面包屑点击访问 /a 仍然会跳转 /a?type=0
#
# 二、不开启 VITE_HISTORY_BREADCRUMB_MODE
# 1）这种使用场景比较简单，一般来说路由的层级不会太深，一般为 2 级，即 /a、/a/b?id=1 这种，/a 不会携带参数或参数可选；
#
# 建议在web端子包的env中配置
# VITE_HISTORY_BREADCRUMB_MODE=N

# 【生产环境（特指打包部署后的环境）隐藏顶栏中的设置（包含主题切换）模块】
# 1）一般来说，web端顶栏中的设置只是在本地开发环境由开发者根据UI设计调试使用，在没有主题切换、布局切换的明确需求时，构建后应该无需显示；
#
# 建议在web端子包的env中配置
# VITE_PRODUCTION_HIDE_SETTINGS=Y

# 【UniApp APPID】
# 建议在uni-app端子包的env中配置
# VITE_UNI_APPID

# 【微信小程序 APPID】
# 建议在uni-app端子包的env中配置
# VITE_WX_APPID

# 【使用环境变量作为前端应用配置】
# 当应用不接入运营管理后台这一套体系时（即没有VITE_APP_ID时），可以通过环境变量来配置前端应用配置，此时你可以配置以下 VITE_FRONT_END_APP_CONF_* 相关的环境变量，不配置将默认为空或'N
# 这里是全局的配置，你可以在子包的env中配置来覆盖它以及VITE_FRONT_END_APP_CONF_*
VITE_USE_ENV_AS_FRONT_END_APP_CONF=N

# 【前端应用配置 - 一级域名或ip】
# 如果你需要开启SSO（VITE_FRONT_END_APP_CONF_ENABLE_SSO=Y），此配置必填，同时你应该配置不同mode下的一级域名或ip（如：test环境下是测试环境的域名，prod环境下是正式环境的域名），以保证在不同环境下都能正确使用SSO
# VITE_FRONT_END_APP_CONF_TOP_DOMAIN=.example.com

# 【前端应用配置 - 是否启用SSO】
# VITE_FRONT_END_APP_CONF_ENABLE_SSO=N

# 【前端应用配置 - 是否跨站SSO】
# VITE_FRONT_END_APP_CONF_CROSS_SITE_SSO=N

# 【前端应用配置 - SSO地址】
# 如果你需要开启SSO（VITE_FRONT_END_APP_CONF_ENABLE_SSO=Y），此配置必填，同时你应该配置不同mode下的SSO地址（如：test环境下是测试环境的SSO地址，prod环境下是正式环境的SSO地址），以保证在不同环境下都能正确使用SSO
# VITE_FRONT_END_APP_CONF_SSO_URL

# 【前端应用配置 - 公司标识】
# VITE_FRONT_END_APP_CONF_COMPANY=quectel

# 【前端应用配置 - 环境标识】
# 可选值有 dev、test、preprod、prod、yanshi，主要用来区分不同的环境，方便做一些环境差异化的处理，当然你也可以指定 mode 来区分不同的环境
# VITE_FRONT_END_APP_CONF_SYS_ENV=dev

# 【前端应用配置 - 静态资源地址】
# 当开启 VITE_USE_ENV_AS_FRONT_END_APP_CONF 时，此配置最好配置下，不然页面中的缺省图等资源可能无法显示，当然你完全可以将这些资源放到项目里来引用，这个根据你的实际情况来定
# VITE_FRONT_END_APP_CONF_ASSETS_URL=https://oss.quectel.com/front-end-assets

# 【前端应用配置 - 官网地址】
# 配置时中文地址在前，英文地址在后，请用英文分号分隔
# VITE_FRONT_END_APP_CONF_PORTAL_URL=https://www.quectel.com.cn;https://www.quectel.com

# 【AI 防腐层 Adapter 使用的 Api Key】
# 可选，未配置则 GUI 生成按钮禁用
# 为了避免你的 Api Key 提交到远程仓库而被泄漏，建议你将此环境变量配置在本地根目录的 /env/.env.customize 文件中，.gitignore 已经默认忽略了 .env.customize 文件
# VITE_AI_GUARD_API_KEY=your-deepseek-api-key
